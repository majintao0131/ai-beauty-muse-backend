# AI Beauty Muse Backend - 环境变量示例
# 使用方式：复制本文件为 .env，填入实际值。勿将 .env 提交到 Git。

# ============== 密钥（必填或按功能选填）==============
# OpenAI（DALL-E、GPT 等）
OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini（对话、命理、参考图换发等）
GEMINI_API_KEY=your-gemini-api-key

# JWT 鉴权（生产环境必须改为强随机串）
SECRET_KEY=your-secret-key-change-in-production

# ============== 可选：代理 ==============
# HTTP_PROXY=http://127.0.0.1:7890
# 留空或不设置则直连

# ============== 服务与 CORS ==============
# HOST=0.0.0.0
# PORT=19000
# DEBUG=false
# CORS_ORIGINS=["http://localhost:8081","http://127.0.0.1:3000"]

# ============== LLM / 模型 ==============
# LLM_PROVIDER=gemini
# OPENAI_MODEL=gpt-4o
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_IMAGE_EDIT_MODEL=gpt-image-1
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_VISION_MODEL=gemini-3-flash-preview
# GEMINI_IMAGE_EDIT_MODEL=gemini-3-pro-image-preview
# GEMINI_DESTINY_MODEL=gemini-3-pro-preview
# IMAGE_EDIT_PROVIDER=gemini
# 换发/参考图换发等调用 Gemini 的超时（秒），若 APP 报 Server disconnected 可调大或检查反向代理超时
# GEMINI_REQUEST_TIMEOUT_SECONDS=300

# ============== 数据库 ==============
# DATABASE_URL=sqlite+aiosqlite:///./ai_beauty_muse.db

# ============== 短信（mock 模式可配测试号）==============
# SMS_PROVIDER=mock
# SMS_TEST_PHONES=13800138000,18912345678
# SMS_TEST_CODE=000000

# ============== OAuth（与 APP 端 docs/oauth-config-example.md 对齐）==============
# API_BASE_URL=https://api.example.com
# OAUTH_PORTAL_URL=https://auth.example.com
# OAUTH_SERVER_URL=https://auth.example.com
# OAUTH_APP_ID=your-app-id-from-portal
# OAUTH_APP_SECRET=your-app-secret-from-portal
# 多个用逗号分隔，需含 Web 回调与 Native deep link
# OAUTH_ALLOWED_REDIRECT_URIS=https://api.example.com/api/oauth/callback,manus20260203215119://oauth/callback
# 可选：Web 登录成功后跳转的前端 URL（不设则回调返回 JSON）
# OAUTH_WEB_SUCCESS_REDIRECT=https://app.example.com/oauth/success

# ============== 配额与会员 ==============
# QUOTA_FREE_LIMIT=10
# QUOTA_MEMBER_LIMIT=10
# 测试环境：去掉限制可设 QUOTA_DISABLED=true；或仅加大次数如 QUOTA_FREE_LIMIT=9999
# QUOTA_DISABLED=false
# MEMBERSHIP_MONTHLY_PRICE=19.9
